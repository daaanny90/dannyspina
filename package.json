{
  "name": "dannyspina",
  "version": "2.0.0",
  "scripts": {
    "dev": "vite dev --host",
    "build": "node ./scripts/create_index.cjs && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "postbuild": "npx svelte-sitemap --domain https://dannyspina.com --ignore 'library' --ignore 'meet' --ignore 'books.html' --ignore 'books/**'"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "commander": "^11.0.0",
    "enquirer": "^2.3.6",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte": "^2.46.1",
    "fs-extra": "^11.1.1",
    "inquirer": "^9.3.8",
    "mdsvex": "^0.12.7",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.3.2",
    "sass": "^1.50.0",
    "simple-git": "^3.36.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.0.0",
    "svelte-preprocess": "^6.0.0",
    "svelte-sitemap": "^2.8.0",
    "tslib": "^2.4.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "type": "module",
  "dependencies": {
    "autoprefixer": "^10.4.13",
    "gray-matter": "^4.0.3",
    "xmlbuilder2": "^4.0.3",
    "xmldom": "^0.6.0"
  }
}
